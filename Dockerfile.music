FROM python:3.11-slim

# ✅ تثبيت المتطلبات الأساسية لـ NTgCalls
RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    ffmpeg \
    libssl-dev \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# ✅ التحقق من التثبيت
RUN python -c "import ntgcalls; print(f'NTgCalls: {ntgcalls.__version__}')" || echo "NTgCalls check failed"

COPY . .

CMD ["python", "-m", "music_bot.main"]
