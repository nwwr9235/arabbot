# ============================================================
# .env — متغيرات البيئة المشتركة
# ⚠️ لا ترفع هذا الملف إلى GitHub
# ============================================================

# ─── Telegram API (مشترك بين البوتين) ───────────────────────
API_ID=12345678
API_HASH=your_api_hash_here

# ─── توكن بوت الإدارة ───────────────────────────────────────
ADMIN_BOT_TOKEN=111111111:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── توكن بوت الموسيقى ──────────────────────────────────────
MUSIC_BOT_TOKEN=222222222:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── MongoDB ─────────────────────────────────────────────────
MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net/arabbot

# ─── مستخدمو sudo (معرفات مفصولة بفاصلة) ────────────────────
SUDO_USERS=123456789,987654321

# ─── المفتاح السري بين البوتين ───────────────────────────────
# غيّره إلى قيمة عشوائية طويلة!
INTERNAL_SECRET=change_this_to_a_long_random_secret_string_32chars

# ─── إعدادات بوت الموسيقى ────────────────────────────────────
MUSIC_API_PORT=8000
# عند التشغيل بدون Docker، ضع عنوان الخادم الفعلي:
# MUSIC_API_URL=http://localhost:8000
